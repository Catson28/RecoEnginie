# ============================================================
# ReconEngine — Environment Variables
# Copiar para .env e preencher os valores reais
# NUNCA commitar o .env com valores reais no git
# ============================================================

# ── Base de dados ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword_change_me
MYSQL_PASSWORD=change_me_in_production

# URL completa para o backend (gerada automaticamente pelo docker-compose)
DATABASE_URL=mysql+pymysql://recon_app:change_me_in_production@db:3306/reconengine

# ── Motor de Matching ─────────────────────────────────────────

# Tier 1 — Exact: tolerância de datas em dias
TIER1_DATE_TOLERANCE_DAYS=2

# Tier 2 — Fuzzy: tolerância de datas e threshold de similaridade (0-100)
TIER2_DATE_TOLERANCE_DAYS=5
TIER2_FUZZY_THRESHOLD=85.0

# Tier 3 — Probable: tolerância de datas
TIER3_DATE_TOLERANCE_DAYS=7

# ── Thresholds de alerta ──────────────────────────────────────
# Pipeline alerta se match rate cair abaixo deste valor (0.0 - 1.0)
ALERT_MIN_MATCH_RATE=0.85

# Pipeline alerta se open items excederem este número
ALERT_MAX_OPEN_ITEMS=50

# Pipeline alerta se valor em aberto exceder este montante (USD)
ALERT_MAX_OPEN_VALUE=100000.0

# ── Notificações por Email ────────────────────────────────────
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Para Gmail: gerar App Password em https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=alerts@reconengine.local
ALERT_TO_EMAILS=finance@company.com,manager@company.com

# ── Notificações Slack ────────────────────────────────────────
ENABLE_SLACK_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Segurança ─────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── App ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
# CORS — URLs que podem aceder à API
CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
